# Paper-Podcast secrets — copy to ".env" and fill in. NEVER commit the real .env.

# --- Resend (email delivery) ---------------------------------------------
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev
RESEND_TO=your-email@example.com

# --- Zotero --------------------------------------------------------------
# API key from https://www.zotero.org/settings/keys (needs library read+write access).
ZOTERO_API_KEY=
# Numeric user ID from https://www.zotero.org/settings/keys (NOT your username).
ZOTERO_LIBRARY_ID=
# "user" for personal library, "group" for shared group library.
ZOTERO_LIBRARY_TYPE=user
